# Runtime environment. Controls log format: "dev" = coloured console, "prod" = JSON.
ENV=dev

# Directory for temporary per-request capture files.
# Cleaned up automatically after each request and by the background cleanup task.
CAPTURE_TMP_DIR=/tmp/visionx_captures

# Path to the SQLite database used for storing capture performance metrics.
# Mount the parent directory as a persistent volume to retain data across restarts.
METRICS_DB_PATH=/data/visionx_metrics.db
