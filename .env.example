# Runtime environment. Controls log format: "dev" = coloured console, "prod" = JSON.
ENV=dev

# Directory for temporary per-request capture files.
# Cleaned up automatically after each request and by the background cleanup task.
CAPTURE_TMP_DIR=/tmp/visionx_captures

# How often (in seconds) the background cleanup task runs.
CLEANUP_INTERVAL_SECONDS=300

# How old (in seconds) a temporary capture directory must be before it is deleted.
MAX_AGE_SECONDS=300

# Path to the SQLite database used for storing capture performance metrics.
# Defaults to /tmp (ephemeral). Override with a persistent path to retain data across restarts.
METRICS_DB_PATH=/tmp/visionx_metrics.db

# ISP sharpness multiplier. 1.0 = IPA default (good for visual inspection).
# Set to 0 for ML-based defect detection pipelines (no artificial edge halos).
CAMERA_SHARPNESS=1.0

# Lock AE and AWB after startup settle. Set to true once your rig lighting is
# stable — every frame will then be pixel-identical under the same conditions.
LOCK_EXPOSURE=false

# Live preview stream resolution (GET /rpi/stream).
# Width must be a multiple of 32, height a multiple of 2 (libcamera alignment).
# Reduce for lower bandwidth; increase for a sharper preview.
STREAM_WIDTH=1280
STREAM_HEIGHT=960

# Maximum frames per second for the preview stream.
STREAM_FPS=15

# JPEG quality for preview stream frames (1–95). Lower = smaller frames, higher latency tolerance.
STREAM_QUALITY=60
